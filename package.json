{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "description": "A Strapi application",
  "scripts": {
    "build": "strapi build",
    "console": "strapi console",
    "deploy": "strapi deploy",
    "dev": "strapi develop",
    "develop": "strapi develop",
    "start": "strapi start",
    "strapi": "strapi",
    "test": "vitest run",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "upgrade": "npx @strapi/upgrade latest",
    "upgrade:dry": "npx @strapi/upgrade latest --dry"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@strapi/plugin-cloud": "5.33.3",
    "@strapi/plugin-documentation": "5.33.3",
    "@strapi/plugin-users-permissions": "5.33.3",
    "@strapi/strapi": "5.33.3",
    "@strapi/utils": "5.33.3",
    "better-sqlite3": "^12.10.0",
    "nodemailer": "^8.0.5",
    "pg": "8.8.0",
    "react": "18.0.0",
    "react-dom": "18.0.0",
    "react-router-dom": "6.26.2",
    "styled-components": "6.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@eslint/js": "9.39.4",
    "@types/koa": "^2.15.0",
    "@types/node": "20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "18",
    "@types/react-dom": "18",
    "baseline-browser-mapping": "^2.10.35",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.6.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "prettier": "3.8.4",
    "typescript": "5",
    "typescript-eslint": "8.61.1",
    "vite": "^5.4.19",
    "vitest": "4.0.15"
  },
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
