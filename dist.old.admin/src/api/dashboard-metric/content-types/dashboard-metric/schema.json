{
    "kind": "collectionType",
    "collectionName": "dashboard_metrics",
    "info": {
        "singularName": "dashboard-metric",
        "pluralName": "dashboard-metrics",
        "displayName": "Dashboard Metric"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "category": {
            "type": "string",
            "required": true
        },
        "periodType": {
            "type": "enumeration",
            "enum": ["today", "week", "month", "year"],
            "required": true,
            "default": "today"
        },
        "periodValue": {
            "type": "string"
        },
        "value": {
            "type": "decimal",
            "required": true
        },
        "meta": {
            "type": "json"
        }
    }
}
