{
    "kind": "collectionType",
    "collectionName": "communication_logs",
    "info": {
        "singularName": "communication-log",
        "pluralName": "communication-logs",
        "displayName": "Communication Log",
        "description": "Historial de interacciones con clientes"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "required": true
        },
        "type": {
            "type": "enumeration",
            "enum": ["call", "email", "campaign"],
            "required": true,
            "default": "call"
        },
        "description": {
            "type": "text"
        },
        "timestamp": {
            "type": "datetime",
            "required": true
        },
        "authorName": {
            "type": "string"
        },
        "client": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::client.client",
            "inversedBy": "communicationLogs"
        },
        "owner": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::user-profile.user-profile",
            "inversedBy": "communicationLogs"
        }
    }
}
