{
  "kind": "collectionType",
  "collectionName": "vehicle_document_categories",
  "info": {
    "singularName": "vehicle-document-category",
    "pluralName": "vehicle-document-categories",
    "displayName": "Categoría de Documento Vehicular",
    "description": "Tipos y categorías maestras de documentos para vehículos"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "templateFile": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["files", "images"]
    }
  }
}
