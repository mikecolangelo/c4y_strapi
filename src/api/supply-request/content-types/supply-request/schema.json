{
  "kind": "collectionType",
  "collectionName": "supply_requests",
  "info": {
    "singularName": "supply-request",
    "pluralName": "supply-requests",
    "displayName": "Supply Request",
    "description": "Solicitudes de insumos básicos por parte de usuarios"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "requestNumber": {
      "type": "string",
      "unique": true
    },
    "type": {
      "type": "enumeration",
      "enum": ["kit_limpieza", "gasolina", "aceite", "otros"],
      "required": true
    },
    "quantity": {
      "type": "integer",
      "required": true,
      "min": 1,
      "default": 1
    },
    "unit": {
      "type": "enumeration",
      "enum": ["unidades", "litros", "galones", "kits"],
      "required": true,
      "default": "unidades"
    },
    "justification": {
      "type": "text",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pendiente", "aprobado", "rechazado", "entregado", "cancelado"],
      "required": true,
      "default": "pendiente"
    },
    "notes": {
      "type": "text"
    },
    "requestedAt": {
      "type": "datetime",
      "required": true
    },
    "approvedAt": {
      "type": "datetime"
    },
    "deliveredAt": {
      "type": "datetime"
    },
    "requester": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile",
      "inversedBy": "supplyRequests"
    },
    "approvedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile",
      "inversedBy": "approvedSupplyRequests"
    },
    "supplyItem": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::supply-item.supply-item",
      "inversedBy": "requests"
    }
  }
}
