{
  "kind": "collectionType",
  "collectionName": "inventory_items",
  "info": {
    "singularName": "inventory-item",
    "pluralName": "inventory-items",
    "displayName": "Inventory Item"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "code": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "description": {
      "type": "string",
      "required": true
    },
    "assignedTo": {
      "type": "string"
    },
    "stock": {
      "type": "float",
      "default": 0,
      "required": true
    },
    "unitCost": {
      "type": "decimal",
      "default": 0
    },
    "salePrice": {
      "type": "decimal",
      "default": 0
    },
    "isActive": {
      "type": "boolean",
      "default": true
    },
    "stockStatus": {
      "type": "enumeration",
      "enum": [
        "high",
        "medium",
        "low"
      ],
      "required": true,
      "default": "medium"
    },
    "minStock": {
      "type": "float"
    },
    "maxStock": {
      "type": "float"
    },
    "unit": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "supplier": {
      "type": "string"
    },
    "lastRestocked": {
      "type": "date"
    },
    "icon": {
      "type": "enumeration",
      "enum": [
        "filter",
        "disc",
        "bolt",
        "tire"
      ],
      "default": "filter"
    },
    "serviceOrders": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::service-order.service-order",
      "mappedBy": "inventoryItems"
    },
    "notes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-note.inventory-note",
      "mappedBy": "item"
    },
    "serviceOrderInventoryItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-order-inventory-item.service-order-inventory-item",
      "mappedBy": "inventoryItem"
    },
    "inventoryMovements": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-movement.inventory-movement",
      "mappedBy": "inventoryItem"
    },
    "inventoryRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-request.inventory-request",
      "mappedBy": "inventoryItem",
      "description": "Solicitudes de piezas relacionadas con este ítem"
    },
    "maintenanceKitItems": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::maintenance-kit-item.maintenance-kit-item",
      "mappedBy": "inventoryItem"
    }
  }
}