{
  "kind": "collectionType",
  "collectionName": "deal_discounts",
  "info": {
    "singularName": "deal-discount",
    "pluralName": "deal-discounts",
    "displayName": "Deal Discount"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
