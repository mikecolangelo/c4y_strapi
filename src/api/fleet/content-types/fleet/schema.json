{
  "kind": "collectionType",
  "collectionName": "fleets",
  "info": {
    "singularName": "fleet",
    "pluralName": "fleets",
    "displayName": "Fleet",
    "description": "Gestión de vehículos en la flota"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "vin": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "price": {
      "type": "decimal",
      "required": true
    },
    "condition": {
      "type": "enumeration",
      "enum": ["nuevo", "usado", "seminuevo"],
      "required": true,
      "default": "nuevo",
      "columnName": "status"
    },
    "brand": {
      "type": "string",
      "required": true
    },
    "model": {
      "type": "string",
      "required": true
    },
    "year": {
      "type": "integer",
      "required": true,
      "min": 1900,
      "max": 2100
    },
    "color": {
      "type": "string"
    },
    "mileage": {
      "type": "integer",
      "min": 0
    },
    "fuelType": {
      "type": "string"
    },
    "transmission": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "imageAlt": {
      "type": "string"
    },
    "preferredBy": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::client.client",
      "mappedBy": "preferredVehicle"
    },
    "assignedDrivers": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::user-profile.user-profile",
      "mappedBy": "assignedVehicles"
    },
    "deals": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::deal.deal",
      "mappedBy": "vehicle"
    },
    "appointments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::appointment.appointment",
      "mappedBy": "vehicle"
    },
    "billingRecords": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::billing-record.billing-record",
      "mappedBy": "vehicle"
    },
    "serviceOrders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-order.service-order",
      "mappedBy": "vehicle"
    },
    "notes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::fleet-note.fleet-note",
      "mappedBy": "vehicle"
    }
  }
}
