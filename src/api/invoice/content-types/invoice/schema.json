{
  "kind": "collectionType",
  "collectionName": "invoices",
  "info": {
    "singularName": "invoice",
    "pluralName": "invoices",
    "displayName": "Invoice",
    "description": "Facturas de financiamiento generadas automáticamente"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "invoiceNumber": {
      "type": "string",
      "unique": true,
      "required": true
    },
    "financing": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::financing.financing",
      "inversedBy": "invoices"
    },
    "client": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile"
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "penaltyAmount": {
      "type": "decimal",
      "default": 0
    },
    "totalAmount": {
      "type": "decimal",
      "required": true
    },
    "dueDate": {
      "type": "date",
      "required": true
    },
    "billingDate": {
      "type": "date",
      "required": true
    },
    "paymentDate": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "overdue", "paid", "cancelled"],
      "default": "pending",
      "required": true
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["cash", "card", "transfer", "yappy", "otros"]
    },
    "quotaNumber": {
      "type": "integer",
      "min": 1
    },
    "notes": {
      "type": "text"
    },
    "isSimulated": {
      "type": "boolean",
      "default": false
    }
  }
}
