{
  "kind": "collectionType",
  "collectionName": "contract_documents",
  "info": {
    "singularName": "contract-document",
    "pluralName": "contract-documents",
    "displayName": "Contract Document"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "documentType": {
      "type": "enumeration",
      "enum": ["contrato", "anexo", "comprobante"],
      "default": "contrato"
    },
    "file": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["files", "images"]
    },
    "deal": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::deal.deal",
      "inversedBy": "documents"
    }
  }
}
