{
  "kind": "collectionType",
  "collectionName": "billing_records",
  "info": {
    "singularName": "billing-record",
    "pluralName": "billing-records",
    "displayName": "Billing Record",
    "description": "Pago individual dentro de un financiamiento (Pago Hijo)"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "receiptNumber": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "amount": {
      "type": "decimal",
      "required": true
    },
    "currency": {
      "type": "string",
      "default": "USD"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pagado", "pendiente", "adelanto", "retrasado", "abonado"],
      "required": true,
      "default": "pendiente"
    },
    "quotaNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "quotasCovered": {
      "type": "integer",
      "default": 1,
      "min": 1
    },
    "quotaAmountCovered": {
      "type": "decimal"
    },
    "advanceCredit": {
      "type": "decimal",
      "default": 0
    },
    "remainingQuotaBalance": {
      "type": "decimal",
      "default": 0,
      "description": "Saldo pendiente por pagar de la cuota actual (diferente de advanceCredit que es crédito para futuras cuotas)"
    },
    "lateFeeAmount": {
      "type": "decimal",
      "default": 0
    },
    "daysLate": {
      "type": "integer",
      "default": 0
    },
    "dueDate": {
      "type": "date",
      "required": true
    },
    "paymentDate": {
      "type": "date"
    },
    "confirmationNumber": {
      "type": "string"
    },
    "verifiedInBank": {
      "type": "boolean",
      "default": false
    },
    "verifiedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile"
    },
    "verifiedAt": {
      "type": "datetime"
    },
    "comments": {
      "type": "text"
    },
    "financing": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::financing.financing",
      "inversedBy": "payments"
    },
    "documents": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::billing-document.billing-document",
      "mappedBy": "record"
    },
    "isSimulated": {
      "type": "boolean",
      "default": false
    }
  }
}
