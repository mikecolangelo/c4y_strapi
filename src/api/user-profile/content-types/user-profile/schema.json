{
  "kind": "collectionType",
  "collectionName": "user_profiles",
  "info": {
    "singularName": "user-profile",
    "pluralName": "user-profiles",
    "displayName": "User Profile",
    "description": "Perfiles extendidos para los roles internos"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "displayName": {
      "type": "string",
      "required": true
    },
    "role": {
      "type": "enumeration",
      "enum": ["admin", "driver", "lead"],
      "required": true
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "string"
    },
    "department": {
      "type": "string"
    },
    "bio": {
      "type": "text"
    },
    "address": {
      "type": "text"
    },
    "dateOfBirth": {
      "type": "date"
    },
    "hireDate": {
      "type": "date"
    },
    "identificationNumber": {
      "type": "string"
    },
    "emergencyContactName": {
      "type": "string"
    },
    "emergencyContactPhone": {
      "type": "string"
    },
    "linkedin": {
      "type": "string"
    },
    "workSchedule": {
      "type": "string"
    },
    "specialties": {
      "type": "text"
    },
    "driverLicense": {
      "type": "string"
    },
    "password": {
      "type": "password",
      "private": true,
      "description": "LEGACY - No usar. La contraseña real vive en users-permissions"
    },
    "billingName": {
      "type": "string"
    },
    "billingAddress": {
      "type": "string"
    },
    "billingTaxId": {
      "type": "string"
    },
    "billingPhone": {
      "type": "string"
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "clients": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::client.client",
      "mappedBy": "salesperson"
    },
    "appointments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::appointment.appointment",
      "mappedBy": "assignedTo"
    },
    "deals": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::deal.deal",
      "mappedBy": "seller"
    },
    "notifications": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::notification.notification",
      "mappedBy": "recipient"
    },
    "communicationLogs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::communication-log.communication-log",
      "mappedBy": "owner"
    },
    "serviceNotes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-note.service-note",
      "mappedBy": "author"
    },
    "serviceOrders": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-order.service-order",
      "mappedBy": "driver"
    },
    "inventoryNotes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-note.inventory-note",
      "mappedBy": "author"
    },
    "assignedVehicles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fleet.fleet",
      "inversedBy": "assignedDrivers"
    },
    "interestedVehicles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fleet.fleet",
      "inversedBy": "interestedDrivers"
    },
    "userAccount": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user",
      "private": true
    },
    "assignedReminders": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::fleet-reminder.fleet-reminder",
      "inversedBy": "assignedUsers"
    },
    "assignedNotifications": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::notification.notification",
      "inversedBy": "assignedUsers",
      "description": "Notificaciones/recordatorios asignados a este usuario"
    },
    "financings": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::financing.financing",
      "mappedBy": "client"
    },
    "driverHistories": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::driver-history.driver-history",
      "mappedBy": "driver",
      "description": "Historial de vehículos conducidos"
    },
    "registeredVehicles": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::fleet.fleet",
      "mappedBy": "createdBy",
      "description": "Vehículos registrados por este usuario"
    },
    "supplyRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::supply-request.supply-request",
      "mappedBy": "requester",
      "description": "Solicitudes de insumos realizadas por este usuario"
    },
    "approvedSupplyRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::supply-request.supply-request",
      "mappedBy": "approvedBy",
      "description": "Solicitudes de insumos aprobadas por este usuario"
    },
    "inventoryRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-request.inventory-request",
      "mappedBy": "requester",
      "description": "Solicitudes de piezas realizadas por este usuario"
    },
    "approvedInventoryRequests": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::inventory-request.inventory-request",
      "mappedBy": "approvedBy",
      "description": "Solicitudes de piezas aprobadas por este usuario"
    }
  }
}
