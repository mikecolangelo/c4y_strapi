{
  "kind": "collectionType",
  "collectionName": "stat_entries",
  "info": {
    "singularName": "stat-entry",
    "pluralName": "stat-entries",
    "displayName": "Stat Entry"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "weekRange": {
      "type": "string",
      "required": true
    },
    "salesAmount": {
      "type": "decimal",
      "default": "0"
    },
    "servicesAmount": {
      "type": "decimal",
      "default": "0"
    },
    "appointmentsCount": {
      "type": "integer",
      "default": 0
    },
    "dailyBreakdown": {
      "type": "json"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile"
    }
  }
}
