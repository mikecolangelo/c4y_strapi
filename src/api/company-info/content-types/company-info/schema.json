{
  "kind": "singleType",
  "collectionName": "company_infos",
  "info": {
    "singularName": "company-info",
    "pluralName": "company-infos",
    "displayName": "Company Info",
    "description": "Información de la empresa para contratos PDF y documentos legales"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "companyName": {
      "type": "string",
      "required": true,
      "description": "Nombre legal de la empresa"
    },
    "legalRepName": {
      "type": "string",
      "required": true,
      "description": "Nombre del representante legal"
    },
    "legalRepNationality": {
      "type": "string",
      "required": false,
      "description": "Nacionalidad del representante legal"
    },
    "legalRepMaritalStatus": {
      "type": "string",
      "required": false,
      "description": "Estado civil del representante legal"
    },
    "legalRepPassport": {
      "type": "string",
      "required": false,
      "description": "Número de pasaporte del representante legal"
    },
    "companyAddress": {
      "type": "text",
      "required": false,
      "description": "Dirección completa de la empresa"
    },
    "registryInfo": {
      "type": "text",
      "required": false,
      "description": "Información del registro mercantil (ficha, documento, sección)"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "description": "Logo de la empresa para contratos y documentos"
    },
    "phone": {
      "type": "string",
      "required": false,
      "description": "Teléfono principal de la empresa"
    },
    "email": {
      "type": "email",
      "required": false,
      "description": "Email principal de la empresa"
    }
  }
}
