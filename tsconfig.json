{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2020"],
    "target": "ES2019",
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "removeComments": true,
    "noEmitOnError": false,
    "noImplicitThis": true,
    "outDir": "dist",
    "rootDir": "."
  },
  "include": ["src/**/*", "config/**/*", "types/**/*", "src/**/*.json"],

  "exclude": [
    "node_modules",
    "dist",
    "dist.old",
    "dist.old.admin",
    ".cache",
    ".tmp",
    "build",
    "src/admin",
    "**/*.test.*",
    "src/plugins/**"
  ]
}
